# Kubernetes
K8S_NAMESPACE=stage
KUBECONFIG=/Users/username/.kube/config

# Database
DATABASE_URL=sqlite:///./mock_manager.db

# Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
BAND_WEBHOOK_URL=https://band.yourcompany.com/webhook/xxx

# Какие переменные отслеживать (оставьте пустым, чтобы отслеживать все)
# TRACKED_VARS=MOCK_ENABLED,USE_MOCK,FEATURE_MOCK,DEBUG_MODE

# App
DEBUG=True
SECRET_KEY=your-secret-key-here